  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "*",
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
