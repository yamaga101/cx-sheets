{
  "name": "sheets-tab-manager",
  "version": "1.4.1",
  "description": "Chrome extension to manage Google Sheets tabs from a side panel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
